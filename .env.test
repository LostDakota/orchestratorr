# Test environment for orchestratorr
# These are dummy values for integration testing

# Radarr
RADARR_URL=http://localhost:7878
RADARR_API_KEY=test-api-key-radarr

# Sonarr (optional)
SONARR_URL=http://localhost:8989
SONARR_API_KEY=test-api-key-sonarr

# Lidarr (optional)
LIDARR_URL=http://localhost:8686
LIDARR_API_KEY=test-api-key-lidarr

# Prowlarr (optional)
PROWLARR_URL=http://localhost:9696
PROWLARR_API_KEY=test-api-key-prowlarr

# FastAPI Configuration
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
FASTAPI_RELOAD=false
LOG_LEVEL=INFO

# Frontend port (custom if port 80 occupied)
FRONTEND_PORT=8081

# CORS Configuration (allow localhost:8081 for testing)
ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://localhost:8081,http://127.0.0.1
