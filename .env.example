# Orchestratorr Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# Radarr Configuration
# ============================================================================
RADARR_URL=http://localhost:7878
RADARR_API_KEY=your-radarr-api-key-here

# ============================================================================
# Sonarr Configuration (Optional - not yet implemented)
# ============================================================================
SONARR_URL=http://localhost:8989
SONARR_API_KEY=your-sonarr-api-key-here

# ============================================================================
# Lidarr Configuration (Optional - not yet implemented)
# ============================================================================
LIDARR_URL=http://localhost:8686
LIDARR_API_KEY=your-lidarr-api-key-here

# ============================================================================
# Prowlarr Configuration (Optional - not yet implemented)
# ============================================================================
PROWLARR_URL=http://localhost:9696
PROWLARR_API_KEY=your-prowlarr-api-key-here

# ============================================================================
# FastAPI Server Configuration
# ============================================================================
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
FASTAPI_RELOAD=true

# ============================================================================
# Frontend Configuration
# ============================================================================
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# Frontend port mapping (host port:container port 80)
# Set this to customize the host port if port 80 is occupied
# Example: FRONTEND_PORT=8081
FRONTEND_PORT=80

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=INFO
